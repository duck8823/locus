import { VerticalBox, HorizontalBox, ListView, ScrollView, LineEdit, Button } from "std-widgets.slint";

// ===== Terminal pane モード (既存) =====

export struct TerminalCell {
    ch: string,
    fg: color,
    bg: color,
    // 描画上の幅 (cell-w 倍数)。1=通常, 2=wide char, 0=spacer (描画しない)
    span: int,
}

export struct TerminalRow {
    cells: [TerminalCell],
}

export component AppWindow inherits Window {
    in property <[TerminalRow]> rows;
    in property <int> cols: 80;
    in property <int> visible-rows: 24;
    in property <length> cell-w: 9px;
    in property <length> cell-h: 18px;
    in property <int> cursor-col: 0;
    in property <int> cursor-row: 0;

    callback key-pressed(string);
    callback resized(length, length);

    title: @tr("locus — Terminal pane");
    preferred-width: 900px;
    preferred-height: 540px;
    background: #0b0b0b;

    forward-focus: focus-area;

    focus-area := FocusScope {
        key-pressed(event) => {
            root.key-pressed(event.text);
            accept
        }

        Rectangle {
            background: #0b0b0b;

            // セルグリッドを行ごとに重ねる
            for row[ri] in root.rows: Rectangle {
                x: 0;
                y: ri * root.cell-h;
                height: root.cell-h;
                width: parent.width;

                for cell[ci] in row.cells: Rectangle {
                    x: ci * root.cell-w;
                    y: 0;
                    width: cell.span * root.cell-w;
                    height: root.cell-h;
                    background: cell.bg;
                    visible: cell.span > 0;

                    Text {
                        text: cell.ch;
                        color: cell.fg;
                        font-family: "Menlo, Consolas, monospace";
                        font-size: 13px;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                    }
                }
            }

            // カーソル
            Rectangle {
                x: root.cursor-col * root.cell-w;
                y: root.cursor-row * root.cell-h;
                width: root.cell-w;
                height: root.cell-h;
                background: #ffffff40;
                border-width: 1px;
                border-color: #ffffff;
            }
        }
    }
}

// ===== Diff viewer モード =====

// DiffLineView.kind: 0=Context, 1=Added, 2=Removed, -1=HunkHeader
export struct DiffLineView {
    kind: int,
    is-hunk-header: bool,
    hunk-index: int,
    old-line-no: string,
    new-line-no: string,
    content: string,
}

export struct DraftEntryView {
    label: string,
    note: string,
}

export struct HistoryEntryView {
    timestamp: string,
    mode: string,
    label: string,
}

export struct IssueContextView {
    number: string,
    title: string,
    state: string,
    body_excerpt: string,
}

export struct PullRequestListItemView {
    number: int,
    number_label: string,
    title: string,
    author: string,
    updated_excerpt: string,
    state: string,
}

export struct DiffFileView {
    file-path: string,
    status-label: string,
    is-unsupported: bool,
    unsupported-reason: string,
    lines: [DiffLineView],
}

export component DiffViewerWindow inherits Window {
    in property <string> pr-title;
    in property <string> head-sha;
    in property <string> base-sha;
    in property <string> pr-body-excerpt;
    in property <[IssueContextView]> linked-issues;
    in property <[DiffFileView]> files;
    in-out property <int> selected-file-index: 0;

    in property <string> current-anchor-label: @tr("(no selection)");
    in property <[DraftEntryView]> draft-entries;
    in-out property <string> note-input-text;

    in-out property <string> preview-text;
    in property <[HistoryEntryView]> history-entries;

    in property <[TerminalRow]> terminal-rows;
    in property <int> terminal-cols: 100;
    in property <int> terminal-rows-count: 30;
    in property <length> terminal-cell-w: 8px;
    in property <length> terminal-cell-h: 16px;
    in property <int> terminal-cursor-col: 0;
    in property <int> terminal-cursor-row: 0;
    in property <bool> terminal-available: false;
    in property <string> terminal-status: @tr("not started");

    in property <[PullRequestListItemView]> pr-list;
    in-out property <int> pr-list-filter: 0; // 0=open, 1=closed, 2=all
    in property <bool> pr-list-loading: false;
    in property <int> current-pr-number: 0;

    callback select-line(int, int, string, string);
    callback select-hunk(int, int);
    callback select-whole-file();
    callback extend-to-range();
    callback add-to-draft(string);
    callback remove-draft-entry(int);
    callback clear-current-selection();
    callback file-switched(int);

    callback refresh-preview();
    callback send-insert-only(string);
    callback send-insert-and-send(string);
    callback send-copy-to-clipboard(string);
    callback terminal-key-pressed(string);

    callback pr-clicked(int);
    callback pr-filter-changed(int);

    title: @tr("locus — diff viewer");
    preferred-width: 1700px;
    preferred-height: 960px;
    background: #101014;

    VerticalBox {
        spacing: 0px;
        padding: 0px;

        // Header with PR context card (title + base/head + body excerpt + linked issues)
        Rectangle {
            height: (root.pr-body-excerpt != "" || root.linked-issues.length > 0) ? 150px : 52px;
            background: #1a1a22;
            VerticalBox {
                padding-left: 16px;
                padding-right: 16px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 4px;
                Text {
                    text: root.pr-title;
                    color: #ffffff;
                    font-size: 14px;
                    font-weight: 600;
                    overflow: elide;
                }
                Text {
                    text: @tr("base") + " " + root.base-sha + "  ←  " + @tr("head") + " " + root.head-sha;
                    color: #8a8a95;
                    font-size: 11px;
                    font-family: "Menlo, Consolas, monospace";
                }
                if root.pr-body-excerpt != "": Text {
                    text: root.pr-body-excerpt;
                    color: #b0b0b8;
                    font-size: 11px;
                    overflow: elide;
                    wrap: word-wrap;
                }
                if root.linked-issues.length > 0: VerticalBox {
                    spacing: 4px;
                    HorizontalBox {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: @tr("linked:");
                            color: #8a8a95;
                            font-size: 10px;
                            vertical-alignment: top;
                        }
                        for issue in root.linked-issues: Rectangle {
                            background: issue.state == "error"
                                ? #2a1010
                                : (issue.state == "closed" ? #2a1a2a : #1a2a1a);
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: issue.state == "error"
                                ? #c07a4e
                                : (issue.state == "closed" ? #5a2a5a : #2a5a2a);
                            VerticalBox {
                                padding-left: 6px;
                                padding-right: 6px;
                                padding-top: 2px;
                                padding-bottom: 2px;
                                spacing: 1px;
                                HorizontalBox {
                                    spacing: 4px;
                                    alignment: start;
                                    Text {
                                        text: issue.number;
                                        color: issue.state == "error"
                                            ? #e58585
                                            : (issue.state == "closed" ? #c07ac0 : #7ac07a);
                                        font-size: 10px;
                                        font-family: "Menlo, Consolas, monospace";
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: issue.title;
                                        color: #d0d0d5;
                                        font-size: 10px;
                                        overflow: elide;
                                    }
                                }
                                if issue.body_excerpt != "": Text {
                                    text: issue.body_excerpt;
                                    color: #8a8a95;
                                    font-size: 9px;
                                    overflow: elide;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }
            }
        }

        HorizontalBox {
            spacing: 0px;
            padding: 0px;

            // PR list sidebar (leftmost)
            Rectangle {
                width: 240px;
                background: #14141a;
                border-width: 1px;
                border-color: #1a1a22;

                VerticalBox {
                    spacing: 0px;
                    padding: 0px;

                    Rectangle {
                        height: 32px;
                        background: #1a1a22;
                        HorizontalBox {
                            padding-left: 10px;
                            padding-right: 10px;
                            alignment: start;
                            Text {
                                text: root.pr-list-loading
                                    ? @tr("PRs (loading…)")
                                    : @tr("PRs") + " (" + root.pr-list.length + ")";
                                color: #ffffff;
                                font-size: 12px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Rectangle {
                        height: 30px;
                        background: #14141a;
                        HorizontalBox {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 4px;
                            Button {
                                text: @tr("Open");
                                checkable: true;
                                checked: root.pr-list-filter == 0;
                                clicked => {
                                    root.pr-list-filter = 0;
                                    root.pr-filter-changed(0);
                                }
                            }
                            Button {
                                text: @tr("Closed");
                                checkable: true;
                                checked: root.pr-list-filter == 1;
                                clicked => {
                                    root.pr-list-filter = 1;
                                    root.pr-filter-changed(1);
                                }
                            }
                            Button {
                                text: @tr("All");
                                checkable: true;
                                checked: root.pr-list-filter == 2;
                                clicked => {
                                    root.pr-list-filter = 2;
                                    root.pr-filter-changed(2);
                                }
                            }
                        }
                    }

                    ListView {
                        vertical-stretch: 1;
                        for pr in root.pr-list: Rectangle {
                            height: 50px;
                            background: pr.number == root.current-pr-number
                                ? #2a2a38
                                : (pr-touch.has-hover ? #1e1e28 : #14141a);
                            border-width: 1px;
                            border-color: #1a1a22;

                            pr-touch := TouchArea {
                                clicked => {
                                    root.pr-clicked(pr.number);
                                }
                            }

                            VerticalBox {
                                padding-left: 8px;
                                padding-right: 8px;
                                padding-top: 4px;
                                padding-bottom: 4px;
                                spacing: 2px;
                                HorizontalBox {
                                    spacing: 4px;
                                    Text {
                                        text: pr.number_label;
                                        color: pr.state == "closed" ? #c07ac0 : #7ac07a;
                                        font-size: 10px;
                                        font-family: "Menlo, Consolas, monospace";
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: pr.author;
                                        color: #8a8a95;
                                        font-size: 10px;
                                    }
                                }
                                Text {
                                    text: pr.title;
                                    color: #d0d0d5;
                                    font-size: 11px;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }

            // File list sidebar
            Rectangle {
                width: 240px;
                background: #14141a;

                ListView {
                    for file[idx] in root.files: Rectangle {
                        height: 26px;
                        background: idx == root.selected-file-index
                            ? #2a2a38
                            : (touch.has-hover ? #1e1e28 : #14141a);

                        touch := TouchArea {
                            clicked => {
                                root.selected-file-index = idx;
                                root.file-switched(idx);
                            }
                        }

                        HorizontalBox {
                            padding-left: 10px;
                            padding-right: 10px;
                            padding-top: 4px;
                            padding-bottom: 4px;
                            spacing: 6px;
                            Text {
                                text: file.status-label;
                                color: #8a8a95;
                                font-size: 10px;
                                font-family: "Menlo, Consolas, monospace";
                                width: 30px;
                            }
                            Text {
                                text: file.file-path;
                                color: #d0d0d5;
                                font-size: 12px;
                                overflow: elide;
                            }
                        }
                    }
                }
            }

            // Center: diff content + selection controls
            Rectangle {
                background: #0b0b0f;

                VerticalBox {
                    spacing: 0px;
                    padding: 0px;

                    // Diff content
                    Rectangle {
                        background: #0b0b0f;

                        if root.files.length > 0
                            && root.files[root.selected-file-index].is-unsupported:
                        VerticalBox {
                            alignment: center;
                            spacing: 8px;
                            Text {
                                text: @tr("unsupported");
                                color: #c07a4e;
                                font-size: 14px;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: root.files[root.selected-file-index].unsupported-reason;
                                color: #8a8a95;
                                font-size: 12px;
                                horizontal-alignment: center;
                            }
                        }

                        if root.files.length > 0
                            && !root.files[root.selected-file-index].is-unsupported:
                        ListView {
                            for line in root.files[root.selected-file-index].lines: Rectangle {
                                height: 18px;
                                background: line.is-hunk-header ? #1a1a28
                                    : (line.kind == 1 ? #102a15
                                    : (line.kind == 2 ? #2a1010 : #0b0b0f));

                                line-touch := TouchArea {
                                    clicked => {
                                        if (line.is-hunk-header) {
                                            root.select-hunk(root.selected-file-index, line.hunk-index);
                                        } else {
                                            root.select-line(
                                                root.selected-file-index,
                                                line.kind,
                                                line.old-line-no,
                                                line.new-line-no
                                            );
                                        }
                                    }
                                }

                                HorizontalBox {
                                    spacing: 0px;
                                    padding: 0px;

                                    Rectangle {
                                        width: 90px;
                                        background: line.is-hunk-header ? #1a1a28 : #08080c;
                                        HorizontalBox {
                                            padding-left: 6px;
                                            padding-right: 6px;
                                            spacing: 6px;
                                            Text {
                                                text: line.old-line-no;
                                                color: #5a5a65;
                                                font-family: "Menlo, Consolas, monospace";
                                                font-size: 11px;
                                                width: 36px;
                                                horizontal-alignment: right;
                                            }
                                            Text {
                                                text: line.new-line-no;
                                                color: #5a5a65;
                                                font-family: "Menlo, Consolas, monospace";
                                                font-size: 11px;
                                                width: 36px;
                                                horizontal-alignment: right;
                                            }
                                        }
                                    }

                                    Text {
                                        text: line.is-hunk-header
                                            ? line.content
                                            : ((line.kind == 1 ? "+ "
                                                : (line.kind == 2 ? "- " : "  "))
                                                + line.content);
                                        color: line.is-hunk-header ? #7a7ac0
                                            : (line.kind == 1 ? #8fd98f
                                            : (line.kind == 2 ? #e58585 : #c8c8d0));
                                        font-family: "Menlo, Consolas, monospace";
                                        font-size: 12px;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }

                    // Selection controls strip
                    Rectangle {
                        height: 80px;
                        background: #14141a;
                        border-width: 1px;
                        border-color: #24242c;

                        VerticalBox {
                            padding: 8px;
                            spacing: 4px;

                            HorizontalBox {
                                spacing: 10px;
                                alignment: start;
                                Text {
                                    text: @tr("Selection:");
                                    color: #8a8a95;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: root.current-anchor-label;
                                    color: #d0d0d5;
                                    font-size: 12px;
                                    font-family: "Menlo, Consolas, monospace";
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                                Button {
                                    text: @tr("File");
                                    clicked => { root.select-whole-file(); }
                                }
                                Button {
                                    text: @tr("Range");
                                    clicked => { root.extend-to-range(); }
                                }
                                Button {
                                    text: @tr("Clear");
                                    clicked => { root.clear-current-selection(); }
                                }
                            }

                            HorizontalBox {
                                spacing: 6px;
                                note-input := LineEdit {
                                    placeholder-text: @tr("note (optional)");
                                    text <=> root.note-input-text;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: @tr("Add to draft");
                                    clicked => {
                                        root.add-to-draft(note-input.text);
                                        root.note-input-text = "";
                                    }
                                }
                            }
                        }
                    }

                    // Preview + send buttons strip
                    Rectangle {
                        height: 180px;
                        background: #14141a;
                        border-width: 1px;
                        border-color: #24242c;

                        VerticalBox {
                            padding: 8px;
                            spacing: 6px;

                            HorizontalBox {
                                spacing: 10px;
                                alignment: start;
                                Text {
                                    text: @tr("Preview:");
                                    color: #8a8a95;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                                Button {
                                    text: @tr("Refresh");
                                    clicked => { root.refresh-preview(); }
                                }
                                Button {
                                    text: @tr("Insert");
                                    enabled: root.terminal-available;
                                    clicked => { root.send-insert-only(root.preview-text); }
                                }
                                Button {
                                    text: @tr("Insert+Send");
                                    enabled: root.terminal-available;
                                    clicked => { root.send-insert-and-send(root.preview-text); }
                                }
                                Button {
                                    text: @tr("Copy");
                                    clicked => { root.send-copy-to-clipboard(root.preview-text); }
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                                background: #0b0b0f;
                                border-width: 1px;
                                border-color: #24242c;
                                preview-input := TextInput {
                                    width: parent.width - 4px;
                                    height: parent.height - 4px;
                                    x: 2px;
                                    y: 2px;
                                    text <=> root.preview-text;
                                    color: #d0d0d5;
                                    font-family: "Menlo, Consolas, monospace";
                                    font-size: 11px;
                                    wrap: word-wrap;
                                    single-line: false;
                                }
                            }
                        }
                    }

                    // Terminal status label
                    Rectangle {
                        height: 22px;
                        background: #1a1a22;
                        HorizontalBox {
                            padding-left: 10px;
                            padding-right: 10px;
                            alignment: start;
                            spacing: 6px;
                            Text {
                                text: @tr("agent:");
                                color: #8a8a95;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.terminal-status;
                                color: root.terminal-available ? #8fd98f : #e58585;
                                font-size: 10px;
                                font-family: "Menlo, Consolas, monospace";
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Terminal pane (bottom)
                    Rectangle {
                        height: 258px;
                        background: #0b0b0b;
                        border-width: 1px;
                        border-color: #24242c;
                        clip: true;

                        terminal-focus := FocusScope {
                            key-pressed(event) => {
                                root.terminal-key-pressed(event.text);
                                accept
                            }

                            // セルグリッド
                            for row[ri] in root.terminal-rows: Rectangle {
                                x: 0;
                                y: ri * root.terminal-cell-h;
                                height: root.terminal-cell-h;
                                width: parent.width;

                                for cell[ci] in row.cells: Rectangle {
                                    x: ci * root.terminal-cell-w;
                                    y: 0;
                                    width: cell.span * root.terminal-cell-w;
                                    height: root.terminal-cell-h;
                                    background: cell.bg;
                                    visible: cell.span > 0;

                                    Text {
                                        text: cell.ch;
                                        color: cell.fg;
                                        font-family: "Menlo, Consolas, monospace";
                                        font-size: 11px;
                                        horizontal-alignment: left;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // カーソル
                            Rectangle {
                                x: root.terminal-cursor-col * root.terminal-cell-w;
                                y: root.terminal-cursor-row * root.terminal-cell-h;
                                width: root.terminal-cell-w;
                                height: root.terminal-cell-h;
                                background: #ffffff40;
                                border-width: 1px;
                                border-color: #ffffff;
                            }

                            terminal-click-area := TouchArea {
                                clicked => {
                                    terminal-focus.focus();
                                }
                            }
                        }
                    }
                }
            }

            // Right: draft + history panel
            Rectangle {
                width: 320px;
                background: #14141a;

                VerticalBox {
                    spacing: 0px;
                    padding: 0px;

                    Rectangle {
                        height: 32px;
                        background: #1a1a22;
                        HorizontalBox {
                            padding-left: 10px;
                            padding-right: 10px;
                            alignment: start;
                            Text {
                                text: @tr("Draft") + " (" + root.draft-entries.length + ")";
                                color: #ffffff;
                                font-size: 12px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }

                    ListView {
                        vertical-stretch: 1;
                        for entry[idx] in root.draft-entries: Rectangle {
                            height: 44px;
                            background: #14141a;
                            border-width: 1px;
                            border-color: #1c1c24;

                            HorizontalBox {
                                padding-left: 8px;
                                padding-right: 8px;
                                padding-top: 4px;
                                padding-bottom: 4px;
                                spacing: 6px;

                                VerticalBox {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    Text {
                                        text: entry.label;
                                        color: #d0d0d5;
                                        font-size: 11px;
                                        font-family: "Menlo, Consolas, monospace";
                                        overflow: elide;
                                    }
                                    Text {
                                        text: entry.note;
                                        color: #8a8a95;
                                        font-size: 11px;
                                        overflow: elide;
                                    }
                                }

                                delete-btn := TouchArea {
                                    width: 24px;
                                    height: 24px;
                                    clicked => {
                                        root.remove-draft-entry(idx);
                                    }
                                    Rectangle {
                                        background: delete-btn.has-hover ? #3a1a1a : transparent;
                                        border-radius: 4px;
                                        Text {
                                            text: "×";
                                            color: #e58585;
                                            font-size: 16px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // History section
                    Rectangle {
                        height: 32px;
                        background: #1a1a22;
                        HorizontalBox {
                            padding-left: 10px;
                            padding-right: 10px;
                            alignment: start;
                            Text {
                                text: @tr("History") + " (" + root.history-entries.length + ")";
                                color: #ffffff;
                                font-size: 12px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Rectangle {
                        height: 180px;
                        background: #14141a;

                        ListView {
                            for h in root.history-entries: Rectangle {
                                height: 44px;
                                background: #14141a;
                                border-width: 1px;
                                border-color: #1c1c24;

                                VerticalBox {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    padding-top: 4px;
                                    padding-bottom: 4px;
                                    spacing: 2px;
                                    HorizontalBox {
                                        spacing: 6px;
                                        Text {
                                            text: h.timestamp;
                                            color: #8a8a95;
                                            font-size: 10px;
                                            font-family: "Menlo, Consolas, monospace";
                                        }
                                        Text {
                                            text: h.mode;
                                            color: #7a9ec0;
                                            font-size: 10px;
                                        }
                                    }
                                    Text {
                                        text: h.label;
                                        color: #d0d0d5;
                                        font-size: 11px;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
