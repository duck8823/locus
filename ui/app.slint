import { VerticalBox, HorizontalBox, ListView, ScrollView, LineEdit, Button } from "std-widgets.slint";

// ===== Terminal pane モード (既存) =====

export struct TerminalCell {
    ch: string,
    fg: color,
    bg: color,
}

export struct TerminalRow {
    cells: [TerminalCell],
}

export component AppWindow inherits Window {
    in property <[TerminalRow]> rows;
    in property <int> cols: 80;
    in property <int> visible-rows: 24;
    in property <length> cell-w: 9px;
    in property <length> cell-h: 18px;
    in property <int> cursor-col: 0;
    in property <int> cursor-row: 0;

    callback key-pressed(string);
    callback resized(length, length);

    title: "locus PoC — Terminal Pane";
    preferred-width: 900px;
    preferred-height: 540px;
    background: #0b0b0b;

    forward-focus: focus-area;

    focus-area := FocusScope {
        key-pressed(event) => {
            root.key-pressed(event.text);
            accept
        }

        Rectangle {
            background: #0b0b0b;

            // セルグリッドを行ごとに重ねる
            for row[ri] in root.rows: Rectangle {
                x: 0;
                y: ri * root.cell-h;
                height: root.cell-h;
                width: parent.width;

                for cell[ci] in row.cells: Rectangle {
                    x: ci * root.cell-w;
                    y: 0;
                    width: root.cell-w;
                    height: root.cell-h;
                    background: cell.bg;

                    Text {
                        text: cell.ch;
                        color: cell.fg;
                        font-family: "Menlo, Consolas, monospace";
                        font-size: 13px;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                    }
                }
            }

            // カーソル
            Rectangle {
                x: root.cursor-col * root.cell-w;
                y: root.cursor-row * root.cell-h;
                width: root.cell-w;
                height: root.cell-h;
                background: #ffffff40;
                border-width: 1px;
                border-color: #ffffff;
            }
        }
    }
}

// ===== Diff viewer モード =====

// DiffLineView.kind: 0=Context, 1=Added, 2=Removed, -1=HunkHeader
export struct DiffLineView {
    kind: int,
    is-hunk-header: bool,
    hunk-index: int,
    old-line-no: string,
    new-line-no: string,
    content: string,
}

export struct DraftEntryView {
    label: string,
    note: string,
}

export struct DiffFileView {
    file-path: string,
    status-label: string,
    is-unsupported: bool,
    unsupported-reason: string,
    lines: [DiffLineView],
}

export component DiffViewerWindow inherits Window {
    in property <string> pr-title;
    in property <string> head-sha;
    in property <string> base-sha;
    in property <[DiffFileView]> files;
    in-out property <int> selected-file-index: 0;

    in property <string> current-anchor-label: "(no selection)";
    in property <[DraftEntryView]> draft-entries;
    in-out property <string> note-input-text;

    callback select-line(int, int, string, string);
    callback select-hunk(int, int);
    callback select-whole-file();
    callback extend-to-range();
    callback add-to-draft(string);
    callback remove-draft-entry(int);
    callback clear-current-selection();
    callback file-switched(int);

    title: "locus — diff viewer";
    preferred-width: 1400px;
    preferred-height: 780px;
    background: #101014;

    VerticalBox {
        spacing: 0px;
        padding: 0px;

        // Header
        Rectangle {
            height: 52px;
            background: #1a1a22;
            VerticalBox {
                padding-left: 16px;
                padding-right: 16px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 2px;
                Text {
                    text: root.pr-title;
                    color: #ffffff;
                    font-size: 14px;
                    font-weight: 600;
                }
                Text {
                    text: "base " + root.base-sha + "  ←  head " + root.head-sha;
                    color: #8a8a95;
                    font-size: 11px;
                    font-family: "Menlo, Consolas, monospace";
                }
            }
        }

        HorizontalBox {
            spacing: 0px;
            padding: 0px;

            // File list sidebar
            Rectangle {
                width: 260px;
                background: #14141a;

                ListView {
                    for file[idx] in root.files: Rectangle {
                        height: 26px;
                        background: idx == root.selected-file-index
                            ? #2a2a38
                            : (touch.has-hover ? #1e1e28 : #14141a);

                        touch := TouchArea {
                            clicked => {
                                root.selected-file-index = idx;
                                root.file-switched(idx);
                            }
                        }

                        HorizontalBox {
                            padding-left: 10px;
                            padding-right: 10px;
                            padding-top: 4px;
                            padding-bottom: 4px;
                            spacing: 6px;
                            Text {
                                text: file.status-label;
                                color: #8a8a95;
                                font-size: 10px;
                                font-family: "Menlo, Consolas, monospace";
                                width: 30px;
                            }
                            Text {
                                text: file.file-path;
                                color: #d0d0d5;
                                font-size: 12px;
                                overflow: elide;
                            }
                        }
                    }
                }
            }

            // Center: diff content + selection controls
            Rectangle {
                background: #0b0b0f;

                VerticalBox {
                    spacing: 0px;
                    padding: 0px;

                    // Diff content
                    Rectangle {
                        background: #0b0b0f;

                        if root.files.length > 0
                            && root.files[root.selected-file-index].is-unsupported:
                        VerticalBox {
                            alignment: center;
                            spacing: 8px;
                            Text {
                                text: "unsupported";
                                color: #c07a4e;
                                font-size: 14px;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: root.files[root.selected-file-index].unsupported-reason;
                                color: #8a8a95;
                                font-size: 12px;
                                horizontal-alignment: center;
                            }
                        }

                        if root.files.length > 0
                            && !root.files[root.selected-file-index].is-unsupported:
                        ListView {
                            for line in root.files[root.selected-file-index].lines: Rectangle {
                                height: 18px;
                                background: line.is-hunk-header ? #1a1a28
                                    : (line.kind == 1 ? #102a15
                                    : (line.kind == 2 ? #2a1010 : #0b0b0f));

                                line-touch := TouchArea {
                                    clicked => {
                                        if (line.is-hunk-header) {
                                            root.select-hunk(root.selected-file-index, line.hunk-index);
                                        } else {
                                            root.select-line(
                                                root.selected-file-index,
                                                line.kind,
                                                line.old-line-no,
                                                line.new-line-no
                                            );
                                        }
                                    }
                                }

                                HorizontalBox {
                                    spacing: 0px;
                                    padding: 0px;

                                    Rectangle {
                                        width: 90px;
                                        background: line.is-hunk-header ? #1a1a28 : #08080c;
                                        HorizontalBox {
                                            padding-left: 6px;
                                            padding-right: 6px;
                                            spacing: 6px;
                                            Text {
                                                text: line.old-line-no;
                                                color: #5a5a65;
                                                font-family: "Menlo, Consolas, monospace";
                                                font-size: 11px;
                                                width: 36px;
                                                horizontal-alignment: right;
                                            }
                                            Text {
                                                text: line.new-line-no;
                                                color: #5a5a65;
                                                font-family: "Menlo, Consolas, monospace";
                                                font-size: 11px;
                                                width: 36px;
                                                horizontal-alignment: right;
                                            }
                                        }
                                    }

                                    Text {
                                        text: line.is-hunk-header
                                            ? line.content
                                            : ((line.kind == 1 ? "+ "
                                                : (line.kind == 2 ? "- " : "  "))
                                                + line.content);
                                        color: line.is-hunk-header ? #7a7ac0
                                            : (line.kind == 1 ? #8fd98f
                                            : (line.kind == 2 ? #e58585 : #c8c8d0));
                                        font-family: "Menlo, Consolas, monospace";
                                        font-size: 12px;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }

                    // Selection controls strip
                    Rectangle {
                        height: 90px;
                        background: #14141a;
                        border-width: 1px;
                        border-color: #24242c;

                        VerticalBox {
                            padding: 10px;
                            spacing: 6px;

                            HorizontalBox {
                                spacing: 10px;
                                alignment: start;
                                Text {
                                    text: "Selection:";
                                    color: #8a8a95;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: root.current-anchor-label;
                                    color: #d0d0d5;
                                    font-size: 12px;
                                    font-family: "Menlo, Consolas, monospace";
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                                Button {
                                    text: "File";
                                    clicked => { root.select-whole-file(); }
                                }
                                Button {
                                    text: "Range";
                                    clicked => { root.extend-to-range(); }
                                }
                                Button {
                                    text: "Clear";
                                    clicked => { root.clear-current-selection(); }
                                }
                            }

                            HorizontalBox {
                                spacing: 6px;
                                note-input := LineEdit {
                                    placeholder-text: "note (optional)";
                                    text <=> root.note-input-text;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: "Add to draft";
                                    clicked => {
                                        root.add-to-draft(note-input.text);
                                        root.note-input-text = "";
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Right: draft panel
            Rectangle {
                width: 300px;
                background: #14141a;

                VerticalBox {
                    spacing: 0px;
                    padding: 0px;

                    Rectangle {
                        height: 32px;
                        background: #1a1a22;
                        HorizontalBox {
                            padding-left: 10px;
                            padding-right: 10px;
                            alignment: start;
                            Text {
                                text: "Draft (" + root.draft-entries.length + ")";
                                color: #ffffff;
                                font-size: 12px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }

                    ListView {
                        for entry[idx] in root.draft-entries: Rectangle {
                            height: 44px;
                            background: #14141a;
                            border-width: 1px;
                            border-color: #1c1c24;

                            HorizontalBox {
                                padding-left: 8px;
                                padding-right: 8px;
                                padding-top: 4px;
                                padding-bottom: 4px;
                                spacing: 6px;

                                VerticalBox {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    Text {
                                        text: entry.label;
                                        color: #d0d0d5;
                                        font-size: 11px;
                                        font-family: "Menlo, Consolas, monospace";
                                        overflow: elide;
                                    }
                                    Text {
                                        text: entry.note;
                                        color: #8a8a95;
                                        font-size: 11px;
                                        overflow: elide;
                                    }
                                }

                                delete-btn := TouchArea {
                                    width: 24px;
                                    height: 24px;
                                    clicked => {
                                        root.remove-draft-entry(idx);
                                    }
                                    Rectangle {
                                        background: delete-btn.has-hover ? #3a1a1a : transparent;
                                        border-radius: 4px;
                                        Text {
                                            text: "×";
                                            color: #e58585;
                                            font-size: 16px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
